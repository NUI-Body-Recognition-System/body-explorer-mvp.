{
  "name": "body-explorer-3d",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Privacy-first 3D spatial-tracking educational app. Zero external APIs.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audio:generate": "node generate_edu_audio.js",
    "audio:generate:check": "node generate_edu_audio.js --check",
    "test:unit": "vitest run --passWithNoTests",
    "test:unit:watch": "vitest",
    "test:browser:facts": "node scripts/test_fact_feedback_browser.mjs",
    "test:fps": "node scripts/manual-fps-check.mjs",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "puppeteer": "^25.3.0",
    "vite": "^8.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "three": "^0.185.0"
  }
}
